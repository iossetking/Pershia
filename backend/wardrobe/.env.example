# .env.example — Plantilla de variables de entorno

# INSTRUCCIONES:
# 1. Llena cada valor con tus credenciales reales


# General 
# Ambiente de ejecución: development | testing | production
APP_ENV=development

# Base de Datos 
DATABASE_URL=postgresql+asyncpg://pershia:pershia_password@db:5432/pershia_db

# JWT 
JWT_SECRET_KEY=cambia_esto_por_un_secret_seguro
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# AWS S3
AWS_ACCESS_KEY_ID=tu_access_key_id
AWS_SECRET_ACCESS_KEY=tu_secret_access_key
AWS_REGION=us-east-1
AWS_S3_BUCKET_NAME=pershia-images

# CloudFront
CLOUDFRONT_URL=https://tu_id.cloudfront.net

# NVIDIA NIM (Qwen)
NVIDIA_API_KEY=tu_nvidia_api_key
NIM_BASE_URL=https://integrate.api.nvidia.com/v1
